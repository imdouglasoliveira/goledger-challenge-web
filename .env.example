# GoLedger External API credentials
# These values are used ONLY on the server-side Fastify BFF.
# NEVER expose them to the frontend or commit a real .env file.

GOLEDGER_BASE_URL=http://ec2-50-19-36-138.compute-1.amazonaws.com
GOLEDGER_USERNAME=your-username
GOLEDGER_PASSWORD=your-password

# TMDB API (for image enrichment)
# Get free token at: https://www.themoviedb.org/settings/api
TMDB_ACCESS_TOKEN=your-tmdb-access-token
